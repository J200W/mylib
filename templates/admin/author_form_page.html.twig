{% extends 'admin/catalog_form_layout.html.twig' %}

{% block catalog_form %}
	<p class="admin-hint">Prénom et nom sont obligatoires.</p>
	{{ form_start(form, { attr: { class: 'admin-catalog-form' } }) }}
	{{ form_errors(form) }}
	<div class="admin-catalog-form__row2">
		<div class="admin-catalog-form__cell">{{ form_row(form.firstname) }}</div>
		<div class="admin-catalog-form__cell">{{ form_row(form.lastname) }}</div>
	</div>
	<div class="admin-catalog-form__actions">
		<a href="{{ path('app_admin') }}#admin-catalogue" class="admin-btn admin-btn--outline">Annuler</a>
		<div class="admin-catalog-form__submit">{{ form_row(form.save) }}</div>
	</div>
	{{ form_end(form) }}
{% endblock %}
